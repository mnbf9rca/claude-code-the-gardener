---
import Layout from '../layouts/Layout.astro';
import plantTimeline from '../data/state/plant_timeline.json';

const timeline = plantTimeline as Record<string, {
  date: string;
  status: string;
  noon_photo_url: string | null;
  photos: string[];
  has_watering: boolean;
}>;


const days = Object.values(timeline).sort((a, b) => b.date.localeCompare(a.date));

const statusBorderColor: Record<string, string> = {
  healthy:  '#6BAA5E',
  stressed: '#D4821E',
  critical: '#E04848',
  unknown:  '#2A2418',
};
---

<Layout title="The Plant">

  <div class="page-header">
    <div class="header-meta">FIELD RECORDS</div>
    <h1 class="page-title">The Plant</h1>
    <div class="header-count">{days.length} days on record</div>
  </div>

  <!-- Legend -->
  <div class="legend">
    {[
      { label: 'Healthy',  color: '#6BAA5E' },
      { label: 'Stressed', color: '#D4821E' },
      { label: 'Critical', color: '#E04848' },
    ].map(s => (
      <span class="legend-item">
        <span class="legend-swatch" style={`background:${s.color}`}></span>
        <span class="legend-label">{s.label}</span>
      </span>
    ))}
    <span class="legend-item">
      <span class="legend-swatch" style="background:#4A7A8A;font-size:0.5rem;display:flex;align-items:center;justify-content:center;color:#A0D0DC">W</span>
      <span class="legend-label">Watered</span>
    </span>
  </div>

  <!-- Contact sheet grid -->
  <div class="contact-sheet">
    {days.map(day => {
      const bc = statusBorderColor[day.status] ?? statusBorderColor.unknown;
      const photo = day.noon_photo_url ?? null;
      return (
        <a href={`/day/${day.date}`} class="sheet-cell" style={`border-left-color:${bc}`}>
          <div class="cell-thumb">
            {photo ? (
              <img
                src={photo}
                alt={`Specimen ${day.date}`}
                class="cell-img"
                loading="lazy"
              />
            ) : (
              <div class="cell-empty">
                <span class="cell-no-photo">—</span>
              </div>
            )}
            {day.has_watering && (
              <span class="water-mark">W</span>
            )}
          </div>
          <div class="cell-footer">
            <span class="cell-date">{day.date.slice(5)}</span>
            <span class="cell-year">{day.date.slice(0, 4)}</span>
          </div>
        </a>
      );
    })}
  </div>

</Layout>

<style>
  .page-header {
    border-bottom: 1px solid #2A2418;
    padding-bottom: 1.25rem;
    margin-bottom: 1.5rem;
    animation: fade-up 0.35s ease both;
  }
  .header-meta {
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #4A3E28;
    margin-bottom: 0.4rem;
  }
  .page-title {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 2rem;
    color: #E8D4A0;
    margin: 0 0 0.4rem;
    line-height: 1;
  }
  .header-count {
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    color: #6A5A3A;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .legend {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    animation: fade-up 0.35s ease both;
    animation-delay: 0.06s;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .legend-swatch {
    width: 8px;
    height: 8px;
    border-radius: 1px;
    flex-shrink: 0;
  }
  .legend-label {
    font-family: 'Martian Mono', monospace;
    font-size: 0.55rem;
    color: #6A5A3A;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .contact-sheet {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 3px;
    animation: fade-up 0.35s ease both;
    animation-delay: 0.12s;
  }

  .sheet-cell {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border-left: 2px solid transparent;
    background: #0D0B07;
    transition: background 0.15s;
  }
  .sheet-cell:hover { background: #131008; }

  .cell-thumb {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #0D0B07;
  }
  .cell-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: sepia(0.1) contrast(1.02);
    transition: transform 0.3s ease;
  }
  .sheet-cell:hover .cell-img { transform: scale(1.04); }

  .cell-empty {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0D0B07;
  }
  .cell-no-photo {
    font-family: 'Martian Mono', monospace;
    font-size: 0.8rem;
    color: #2A2018;
  }

  .water-mark {
    position: absolute;
    top: 3px;
    right: 3px;
    font-family: 'Martian Mono', monospace;
    font-size: 0.45rem;
    color: #A0D0DC;
    background: rgba(16, 40, 50, 0.85);
    padding: 1px 3px;
    letter-spacing: 0.05em;
    border: 1px solid #2A4A55;
  }

  .cell-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 3px 4px;
    background: #0C0A06;
    border-top: 1px solid #1C1408;
  }
  .cell-date {
    font-family: 'Martian Mono', monospace;
    font-size: 0.5rem;
    color: #6A5A3A;
    letter-spacing: 0.04em;
  }
  .sheet-cell:hover .cell-date { color: #F0A32C; }
  .cell-year {
    font-family: 'Martian Mono', monospace;
    font-size: 0.45rem;
    color: #3E3420;
    letter-spacing: 0.03em;
  }

  @media (max-width: 1100px) {
    .contact-sheet { grid-template-columns: repeat(5, 1fr); }
  }
  @media (max-width: 800px) {
    .contact-sheet { grid-template-columns: repeat(4, 1fr); }
  }
  @media (max-width: 600px) {
    .contact-sheet { grid-template-columns: repeat(3, 1fr); }
  }
</style>
