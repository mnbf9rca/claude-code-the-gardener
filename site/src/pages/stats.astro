---
import Layout from '../layouts/Layout.astro';
import aiStats from '../data/state/ai_stats.json';
import sensorDaily from '../data/state/sensor_stats_daily.json';

type DayAI = {
  sessions: number;
  input_tokens: number;
  output_tokens: number;
  estimated_cost_usd: number;
  tool_calls: Record<string, number>;
};

const stats = aiStats as Record<string, DayAI>;
const totalSessions  = Object.values(stats).reduce((s, d) => s + (d.sessions ?? 0), 0);
const totalCost      = Object.values(stats).reduce((s, d) => s + (d.estimated_cost_usd ?? 0), 0);
const totalInput     = Object.values(stats).reduce((s, d) => s + (d.input_tokens ?? 0), 0);
const totalOutput    = Object.values(stats).reduce((s, d) => s + (d.output_tokens ?? 0), 0);
const daysMonitored  = Object.keys(stats).length;
const avgCostPerDay  = daysMonitored > 0 ? totalCost / daysMonitored : 0;

const summaryReadouts = [
  { key: 'DAYS MONITORED',  val: String(daysMonitored) },
  { key: 'TOTAL SESSIONS',  val: totalSessions.toLocaleString() },
  { key: 'INPUT TOKENS',    val: totalInput.toLocaleString() },
  { key: 'OUTPUT TOKENS',   val: totalOutput.toLocaleString() },
  { key: 'TOTAL COST',      val: `$${totalCost.toFixed(2)}` },
  { key: 'AVG COST / DAY',  val: `$${avgCostPerDay.toFixed(3)}` },
];
---

<Layout title="Stats">

  <div class="page-header">
    <div class="header-meta">OPERATIONAL METRICS</div>
    <h1 class="page-title">Stats</h1>
    <div class="header-count">Since monitoring began</div>
  </div>

  <!-- Instrument readout strip -->
  <div class="readout-strip">
    {summaryReadouts.map(r => (
      <div class="readout-cell">
        <div class="readout-key">{r.key}</div>
        <div class="readout-val">{r.val}</div>
      </div>
    ))}
  </div>

  <!-- Daily cost chart -->
  <div class="date-range-bar">
    <span class="dr-label">RANGE</span>
    <input type="date" id="drFrom" class="dr-input" />
    <span class="dr-sep">—</span>
    <input type="date" id="drTo" class="dr-input" />
    <button id="drReset" class="dr-reset">ALL</button>
  </div>
  <section class="chart-section">
    <div class="section-rule">DAILY COST (USD)</div>
    <div class="chart-frame">
      <canvas id="costChart"></canvas>
      <div class="chart-loading" id="costLoading">LOADING TELEMETRY&hellip;</div>
      <div class="chart-error" id="costError" hidden>NO TELEMETRY AVAILABLE</div>
    </div>
  </section>

  <!-- Hourly moisture chart -->
  <section class="chart-section">
    <div class="section-rule">MOISTURE (HOURLY)</div>
    <div class="chart-frame">
      <canvas id="moistureChart"></canvas>
      <div class="chart-loading" id="moistureLoading">LOADING TELEMETRY&hellip;</div>
      <div class="chart-error" id="moistureError" hidden>NO TELEMETRY AVAILABLE</div>
    </div>
  </section>

  <!-- Tool call breakdown (client-rendered, reacts to date filter) -->
  <section id="toolSection" class="chart-section" hidden>
    <div class="section-rule" id="toolSectionRule">TOOL CALL FREQUENCY</div>
    <div id="toolTableContainer"></div>
  </section>

</Layout>

<!-- Charts via esm.sh — loaded inline so Vite doesn't attempt to bundle it -->
<script is:inline type="module">
  import Chart from 'https://esm.sh/chart.js@4.4.9/auto';
  import 'https://esm.sh/chartjs-adapter-date-fns@3.0.0?deps=chart.js@4.4.9';

  const AMBER      = 'rgba(240,163,44,0.85)';
  const AMBER_DIM  = 'rgba(240,163,44,0.25)';
  const SAGE       = 'rgba(107,170,94,0.9)';
  const SAGE_FILL  = 'rgba(107,170,94,0.08)';
  const GRID       = '#1C1408';
  const TICK       = '#6A5A3A';

  const baseFont = { family: "'Martian Mono', 'Courier New', monospace", size: 10 };

  Chart.defaults.color = TICK;
  Chart.defaults.font  = baseFont;

  function hideLoader(id) { const el = document.getElementById(id); if (el) el.hidden = true; }
  function showError(id)  { const el = document.getElementById(id); if (el) el.hidden = false; }

  /** Safe DOM element builder — no innerHTML on data */
  function mkEl(tag, attrs, ...children) {
    const el = document.createElement(tag);
    for (const [k, v] of Object.entries(attrs ?? {})) {
      if (k === 'className') el.className = v;
      else if (k === 'style') el.style.cssText = v;
      else el.setAttribute(k, v);
    }
    for (const child of children) {
      if (typeof child === 'string') el.appendChild(document.createTextNode(child));
      else if (child) el.appendChild(child);
    }
    return el;
  }

  const drFrom  = document.getElementById('drFrom');
  const drTo    = document.getElementById('drTo');
  const drReset = document.getElementById('drReset');

  try {
    const [aiRes, hourlyRes, dailyRes] = await Promise.all([
      fetch('/state/ai_stats.json'),
      fetch('/state/sensor_stats_hourly.json'),
      fetch('/state/sensor_stats_daily.json'),
    ]);

    const aiData     = aiRes.ok     ? await aiRes.json()     : {};
    const hourlyData = hourlyRes.ok ? await hourlyRes.json() : {};
    const dailyData  = dailyRes.ok  ? await dailyRes.json()  : {};

    const allCostDates = Object.keys(aiData).sort();
    const allHourKeys  = Object.keys(hourlyData).sort();

    if (allCostDates.length > 0) {
      drFrom.min = allCostDates[0];  drFrom.max = allCostDates.at(-1);
      drTo.min   = allCostDates[0];  drTo.max   = allCostDates.at(-1);
    } else {
      hideLoader('costLoading'); showError('costError');
    }

    // ── Cost chart ────────────────────────────────────────────────────────────
    let costChart = null;

    function buildCostChart(from, to) {
      const filtered = allCostDates.filter(d => (!from || d >= from) && (!to || d <= to));
      const values   = filtered.map(d => aiData[d].estimated_cost_usd ?? 0);
      if (costChart) {
        costChart.data.labels = filtered.map(d => d.slice(5));
        costChart.data.datasets[0].data = values;
        costChart.update();
      } else {
        hideLoader('costLoading');
        costChart = new Chart(document.getElementById('costChart'), {
          type: 'bar',
          data: { labels: filtered.map(d => d.slice(5)), datasets: [{ data: values, backgroundColor: AMBER_DIM, borderColor: AMBER, borderWidth: 1, borderRadius: 0 }] },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: { backgroundColor: '#1C1408', borderColor: '#2A2418', borderWidth: 1, titleColor: '#F0A32C', bodyColor: '#E8D4A0', callbacks: { label: ctx => ` $${ctx.parsed.y.toFixed(4)}` } },
            },
            scales: {
              x: { grid: { color: GRID }, ticks: { color: TICK, maxTicksLimit: 14, font: baseFont }, border: { color: '#2A2418' } },
              y: { grid: { color: GRID }, ticks: { color: TICK, font: baseFont, callback: v => `$${Number(v).toFixed(3)}` }, border: { color: '#2A2418' }, beginAtZero: true },
            },
          },
        });
      }
    }

    // ── Moisture chart ────────────────────────────────────────────────────────
    let moistureChart = null;

    function buildMoistureChart(from, to) {
      const filteredKeys = allHourKeys.filter(k => { const d = k.slice(0, 10); return (!from || d >= from) && (!to || d <= to); });
      if (filteredKeys.length === 0) {
        hideLoader('moistureLoading'); showError('moistureError');
        if (moistureChart) { moistureChart.destroy(); moistureChart = null; }
        return;
      }
      const moisturePoints = filteredKeys.map(k => ({ x: k, y: hourlyData[k]?.moisture?.avg ?? null }));
      const validVals = moisturePoints.map(p => p.y).filter(v => v != null);
      const yMin   = validVals.length ? Math.min(...validVals) : 0;
      const yMax   = validVals.length ? Math.max(...validVals) : 0;
      const fixedY = yMin - (yMax - yMin) * 0.05;

      const windowStart = filteredKeys[0]?.slice(0, 10);
      const windowEnd   = filteredKeys.at(-1)?.slice(0, 10);
      const waterPoints = [];
      for (const [day, dayStats] of Object.entries(dailyData)) {
        if (!windowStart || !windowEnd || day < windowStart || day > windowEnd) continue;
        for (const evt of dayStats?.water?.events ?? []) waterPoints.push({ x: evt.timestamp, y: fixedY });
      }

      if (moistureChart) { moistureChart.destroy(); moistureChart = null; }
      hideLoader('moistureLoading');
      moistureChart = new Chart(document.getElementById('moistureChart'), {
        type: 'line',
        data: {
          datasets: [
            { data: moisturePoints, borderColor: SAGE, backgroundColor: SAGE_FILL, showLine: true, tension: 0.35, pointRadius: 0, pointHoverRadius: 3, fill: true, borderWidth: 1.5, order: 2 },
            { data: waterPoints, type: 'scatter', pointStyle: 'triangle', pointRadius: 6, pointHoverRadius: 7, backgroundColor: 'rgba(160,208,220,0.9)', borderColor: 'transparent', showLine: false, order: 1 },
          ],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: { filter: item => item.datasetIndex === 0, backgroundColor: '#1C1408', borderColor: '#2A2418', borderWidth: 1, titleColor: SAGE, bodyColor: '#E8D4A0', callbacks: { label: ctx => ` ${ctx.parsed.y != null ? ctx.parsed.y.toFixed(1) : '—'}` } },
          },
          scales: {
            x: { type: 'time', time: { unit: 'day', displayFormats: { day: 'dd MMM' } }, adapters: { date: {} }, grid: { color: GRID }, ticks: { color: TICK, font: baseFont }, border: { color: '#2A2418' } },
            y: { grid: { color: GRID }, ticks: { color: TICK, font: baseFont }, border: { color: '#2A2418' } },
          },
        },
      });
    }

    // ── Tool table (DOM-built, no innerHTML on data) ───────────────────────
    function buildToolTable(from, to) {
      const filtered = allCostDates.filter(d => (!from || d >= from) && (!to || d <= to));
      const toolCounts = {};
      for (const d of filtered)
        for (const [tool, count] of Object.entries(aiData[d].tool_calls ?? {}))
          toolCounts[tool] = (toolCounts[tool] ?? 0) + count;

      const tools      = Object.entries(toolCounts).sort(([, a], [, b]) => b - a).slice(0, 20);
      const totalCalls = tools.reduce((s, [, c]) => s + c, 0);
      const maxCalls   = tools[0]?.[1] ?? 1;

      const section   = document.getElementById('toolSection');
      const rule      = document.getElementById('toolSectionRule');
      const container = document.getElementById('toolTableContainer');
      if (tools.length === 0) { section.hidden = true; return; }

      rule.textContent = `TOOL CALL FREQUENCY \u2014 TOP ${tools.length}`;
      section.hidden = false;

      const tbody = document.createElement('tbody');
      for (const [i, [tool, count]] of tools.entries()) {
        const barWrap = mkEl('div', { className: 'tool-bar-wrap' },
          mkEl('span', { className: 'tool-name' }, tool),
          mkEl('span', { className: 'tool-bar', style: `width:${Math.round((count / maxCalls) * 120)}px` })
        );
        tbody.appendChild(mkEl('tr', { className: 'tr' },
          mkEl('td', { className: 'td td-rank' }, String(i + 1).padStart(2, '0')),
          mkEl('td', { className: 'td' }, barWrap),
          mkEl('td', { className: 'td td-right td-val' }, count.toLocaleString()),
          mkEl('td', { className: 'td td-right td-dim' }, `${((count / totalCalls) * 100).toFixed(1)}%`)
        ));
      }
      const thead = mkEl('thead', {},
        mkEl('tr', {},
          mkEl('th', { className: 'th' }, 'RANK'),
          mkEl('th', { className: 'th' }, 'TOOL'),
          mkEl('th', { className: 'th th-right' }, 'CALLS'),
          mkEl('th', { className: 'th th-right' }, 'SHARE')
        )
      );
      container.replaceChildren(mkEl('div', { className: 'tool-table-wrap' }, mkEl('table', { className: 'tool-table' }, thead, tbody)));
    }

    // ── Unified update ────────────────────────────────────────────────────────
    function update() {
      buildCostChart(drFrom.value, drTo.value);
      buildMoistureChart(drFrom.value, drTo.value);
      buildToolTable(drFrom.value, drTo.value);
    }
    drFrom.addEventListener('change', update);
    drTo.addEventListener('change',   update);
    drReset.addEventListener('click', () => { drFrom.value = ''; drTo.value = ''; update(); });
    update();

  } catch (err) {
    console.error('[stats] load failed:', err);
    hideLoader('costLoading');     showError('costError');
    hideLoader('moistureLoading'); showError('moistureError');
  }
</script>

<style>
  .page-header {
    border-bottom: 1px solid #2A2418;
    padding-bottom: 1.25rem;
    margin-bottom: 2rem;
    animation: fade-up 0.35s ease both;
  }
  .header-meta {
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #4A3E28;
    margin-bottom: 0.4rem;
  }
  .page-title {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 2rem;
    color: #E8D4A0;
    margin: 0 0 0.4rem;
    line-height: 1;
  }
  .header-count {
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    color: #6A5A3A;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Readout strip */
  .readout-strip {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1px;
    background: #1C1408;
    border: 1px solid #2A2418;
    margin-bottom: 2.5rem;
    animation: fade-up 0.35s ease both;
    animation-delay: 0.06s;
  }
  .readout-cell {
    background: #0D0B07;
    padding: 1rem 0.75rem;
  }
  .readout-key {
    font-family: 'Martian Mono', monospace;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #4A3E28;
    margin-bottom: 0.5rem;
  }
  .readout-val {
    font-family: 'Martian Mono', monospace;
    font-size: 1.1rem;
    color: #F0A32C;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  /* Date range bar */
  .date-range-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .dr-label {
    font-family: 'Martian Mono', monospace;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #4A3E28;
  }
  .dr-input {
    background: #0D0B07;
    border: 1px solid #2A2418;
    color: #C8B888;
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    padding: 0.25rem 0.4rem;
    outline: none;
    cursor: pointer;
    color-scheme: dark;
  }
  .dr-input:focus { border-color: #F0A32C; }
  .dr-sep {
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    color: #3E3420;
  }
  .dr-reset {
    background: transparent;
    border: 1px solid #2A2418;
    color: #6A5A3A;
    font-family: 'Martian Mono', monospace;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.5rem;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  .dr-reset:hover { color: #F0A32C; border-color: #F0A32C; }

  /* Chart sections */
  .chart-section {
    margin-bottom: 2.5rem;
    animation: fade-up 0.35s ease both;
    animation-delay: 0.1s;
  }
  .section-rule {
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #4A3E28;
    border-bottom: 1px solid #2A2418;
    padding-bottom: 0.4rem;
    margin-bottom: 0.75rem;
  }
  .chart-frame {
    background: #0D0B07;
    border: 1px solid #2A2418;
    padding: 1rem;
    height: 240px;
    position: relative;
  }
  .chart-frame canvas {
    width: 100% !important;
    height: 100% !important;
  }
  .chart-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    color: #3E3420;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    pointer-events: none;
  }
  .chart-error {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Martian Mono', monospace;
    font-size: 0.65rem;
    color: #4A3E28;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* Tool table */
  .tool-table-wrap { overflow-x: auto; }
  .tool-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
  }
  .th {
    text-align: left;
    padding: 0 0 0.4rem;
    color: #4A3E28;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 1px solid #2A2418;
  }
  .th-right { text-align: right; }
  .tr { border-bottom: 1px solid #1C1408; }
  .tr:hover { background: #100E06; }
  .td { padding: 0.35rem 0; color: #7A6A42; vertical-align: middle; }
  .td-rank { color: #3E3420; width: 2.5rem; }
  .td-right { text-align: right; }
  .td-val { color: #F0A32C; }
  .td-dim { color: #4A3E28; }

  .tool-bar-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .tool-name {
    min-width: 180px;
    color: #C8B888;
  }
  .tool-bar {
    display: inline-block;
    height: 4px;
    background: #2A2418;
    flex-shrink: 0;
    position: relative;
  }
  .tool-bar::after {
    content: '';
    position: absolute;
    inset: 0;
    background: #F0A32C;
    opacity: 0.4;
  }

  @media (max-width: 900px) {
    .readout-strip { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .readout-strip { grid-template-columns: repeat(2, 1fr); }
  }
</style>
