---
import Layout from '../layouts/Layout.astro';
import aiStats from '../data/state/ai_stats.json';
import sensorDaily from '../data/state/sensor_stats_daily.json';

type DayAI = {
  sessions: number;
  input_tokens: number;
  output_tokens: number;
  estimated_cost_usd: number;
  tool_calls: Record<string, number>;
};

const stats = aiStats as Record<string, DayAI>;
const totalSessions  = Object.values(stats).reduce((s, d) => s + (d.sessions ?? 0), 0);
const totalCost      = Object.values(stats).reduce((s, d) => s + (d.estimated_cost_usd ?? 0), 0);
const totalInput     = Object.values(stats).reduce((s, d) => s + (d.input_tokens ?? 0), 0);
const totalOutput    = Object.values(stats).reduce((s, d) => s + (d.output_tokens ?? 0), 0);
const daysMonitored  = Object.keys(stats).length;
const avgCostPerDay  = daysMonitored > 0 ? totalCost / daysMonitored : 0;

const allToolCalls: Record<string, number> = {};
for (const day of Object.values(stats)) {
  for (const [tool, count] of Object.entries(day.tool_calls ?? {})) {
    allToolCalls[tool] = (allToolCalls[tool] ?? 0) + count;
  }
}
const topTools = Object.entries(allToolCalls)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 20);

const summaryReadouts = [
  { key: 'DAYS MONITORED',  val: String(daysMonitored) },
  { key: 'TOTAL SESSIONS',  val: totalSessions.toLocaleString() },
  { key: 'INPUT TOKENS',    val: totalInput.toLocaleString() },
  { key: 'OUTPUT TOKENS',   val: totalOutput.toLocaleString() },
  { key: 'TOTAL COST',      val: `$${totalCost.toFixed(2)}` },
  { key: 'AVG COST / DAY',  val: `$${avgCostPerDay.toFixed(3)}` },
];
---

<Layout title="Stats">

  <div class="page-header">
    <div class="header-meta">OPERATIONAL METRICS</div>
    <h1 class="page-title">Stats</h1>
    <div class="header-count">Since monitoring began</div>
  </div>

  <!-- Instrument readout strip -->
  <div class="readout-strip">
    {summaryReadouts.map(r => (
      <div class="readout-cell">
        <div class="readout-key">{r.key}</div>
        <div class="readout-val">{r.val}</div>
      </div>
    ))}
  </div>

  <!-- Daily cost chart -->
  <section class="chart-section">
    <div class="section-rule">DAILY COST (USD)</div>
    <div class="chart-frame">
      <canvas id="costChart"></canvas>
      <div class="chart-loading" id="costLoading">LOADING TELEMETRY&hellip;</div>
      <div class="chart-error" id="costError" hidden>NO TELEMETRY AVAILABLE</div>
    </div>
  </section>

  <!-- Hourly moisture chart -->
  <section class="chart-section">
    <div class="section-rule">MOISTURE &mdash; LAST 7 DAYS (HOURLY)</div>
    <div class="chart-frame">
      <canvas id="moistureChart"></canvas>
      <div class="chart-loading" id="moistureLoading">LOADING TELEMETRY&hellip;</div>
      <div class="chart-error" id="moistureError" hidden>NO TELEMETRY AVAILABLE</div>
    </div>
  </section>

  <!-- Tool call breakdown -->
  {topTools.length > 0 && (
    <section class="chart-section">
      <div class="section-rule">TOOL CALL FREQUENCY &mdash; TOP {topTools.length}</div>
      <div class="tool-table-wrap">
        <table class="tool-table">
          <thead>
            <tr>
              <th class="th">RANK</th>
              <th class="th">TOOL</th>
              <th class="th th-right">CALLS</th>
              <th class="th th-right">SHARE</th>
            </tr>
          </thead>
          <tbody>
            {(() => {
              const maxCalls = topTools[0]?.[1] ?? 1;
              const totalCalls = topTools.reduce((s, [, c]) => s + c, 0);
              return topTools.map(([tool, count], i) => (
                <tr class="tr">
                  <td class="td td-rank">{String(i + 1).padStart(2, '0')}</td>
                  <td class="td">
                    <div class="tool-bar-wrap">
                      <span class="tool-name">{tool}</span>
                      <span
                        class="tool-bar"
                        style={`width:${Math.round((count / maxCalls) * 120)}px`}
                      ></span>
                    </div>
                  </td>
                  <td class="td td-right td-val">{count.toLocaleString()}</td>
                  <td class="td td-right td-dim">{((count / totalCalls) * 100).toFixed(1)}%</td>
                </tr>
              ));
            })()}
          </tbody>
        </table>
      </div>
    </section>
  )}

</Layout>

<!-- Chart.js via CDN — loaded inline so Vite doesn't attempt to bundle it -->
<script is:inline type="module">
  import Chart from 'https://cdn.jsdelivr.net/npm/chart.js@4.4.9/auto/+esm';

  const AMBER      = 'rgba(240,163,44,0.85)';
  const AMBER_DIM  = 'rgba(240,163,44,0.25)';
  const SAGE       = 'rgba(107,170,94,0.9)';
  const SAGE_FILL  = 'rgba(107,170,94,0.08)';
  const GRID       = '#1C1408';
  const TICK       = '#6A5A3A';

  const baseFont = { family: "'Martian Mono', 'Courier New', monospace", size: 10 };

  Chart.defaults.color = TICK;
  Chart.defaults.font  = baseFont;

  function hideLoader(id) {
    const el = document.getElementById(id);
    if (el) el.hidden = true;
  }

  function showError(id) {
    const el = document.getElementById(id);
    if (el) el.hidden = false;
  }

  try {
  const [aiRes, hourlyRes] = await Promise.all([
    fetch('/state/ai_stats.json'),
    fetch('/state/sensor_stats_hourly.json'),
  ]);

  if (aiRes.ok) {
    const aiData = await aiRes.json();
    const costDates  = Object.keys(aiData).sort();
    const costValues = costDates.map(d => aiData[d].estimated_cost_usd ?? 0);

    if (costDates.length === 0) {
      hideLoader('costLoading');
      showError('costError');
    } else {
    hideLoader('costLoading');
    new Chart(document.getElementById('costChart'), {
      type: 'bar',
      data: {
        labels: costDates.map(d => d.slice(5)),
        datasets: [{
          data: costValues,
          backgroundColor: AMBER_DIM,
          borderColor: AMBER,
          borderWidth: 1,
          borderRadius: 0,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1C1408',
            borderColor: '#2A2418',
            borderWidth: 1,
            titleColor: '#F0A32C',
            bodyColor: '#E8D4A0',
            callbacks: {
              label: ctx => ` $${ctx.parsed.y.toFixed(4)}`,
            },
          },
        },
        scales: {
          x: {
            grid: { color: GRID },
            ticks: { color: TICK, maxTicksLimit: 14, font: baseFont },
            border: { color: '#2A2418' },
          },
          y: {
            grid: { color: GRID },
            ticks: {
              color: TICK,
              font: baseFont,
              callback: v => `$${Number(v).toFixed(3)}`,
            },
            border: { color: '#2A2418' },
            beginAtZero: true,
          },
        },
      },
    });
    } // end else (costDates.length > 0)
  } else {
    hideLoader('costLoading');
    showError('costError');
  }

  if (hourlyRes.ok) {
    const hourlyData = await hourlyRes.json();
    const hourKeys  = Object.keys(hourlyData).sort().slice(-168);
    const moistVals = hourKeys.map(h => hourlyData[h]?.moisture?.avg ?? null);

    if (hourKeys.length === 0) {
      hideLoader('moistureLoading');
      showError('moistureError');
    } else {
    hideLoader('moistureLoading');
    new Chart(document.getElementById('moistureChart'), {
      type: 'line',
      data: {
        labels: hourKeys.map(h => h.slice(5, 16).replace('T', ' ')),
        datasets: [{
          data: moistVals,
          borderColor: SAGE,
          backgroundColor: SAGE_FILL,
          tension: 0.35,
          pointRadius: 0,
          pointHoverRadius: 3,
          fill: true,
          borderWidth: 1.5,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1C1408',
            borderColor: '#1C2A1C',
            borderWidth: 1,
            titleColor: '#6BAA5E',
            bodyColor: '#E8D4A0',
            callbacks: {
              label: ctx => ` ${ctx.parsed.y != null ? ctx.parsed.y.toFixed(1) : '—'}`,
            },
          },
        },
        scales: {
          x: {
            grid: { color: GRID },
            ticks: { color: TICK, maxTicksLimit: 14, font: baseFont },
            border: { color: '#2A2418' },
          },
          y: {
            grid: { color: GRID },
            ticks: { color: TICK, font: baseFont },
            border: { color: '#2A2418' },
          },
        },
      },
    });
    } // end else (hourKeys.length > 0)
  } else {
    hideLoader('moistureLoading');
    showError('moistureError');
  }
  } catch (_) {
    hideLoader('costLoading');
    showError('costError');
    hideLoader('moistureLoading');
    showError('moistureError');
  }
</script>

<style>
  .page-header {
    border-bottom: 1px solid #2A2418;
    padding-bottom: 1.25rem;
    margin-bottom: 2rem;
    animation: fade-up 0.35s ease both;
  }
  .header-meta {
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #4A3E28;
    margin-bottom: 0.4rem;
  }
  .page-title {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 2rem;
    color: #E8D4A0;
    margin: 0 0 0.4rem;
    line-height: 1;
  }
  .header-count {
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    color: #6A5A3A;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Readout strip */
  .readout-strip {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1px;
    background: #1C1408;
    border: 1px solid #2A2418;
    margin-bottom: 2.5rem;
    animation: fade-up 0.35s ease both;
    animation-delay: 0.06s;
  }
  .readout-cell {
    background: #0D0B07;
    padding: 1rem 0.75rem;
  }
  .readout-key {
    font-family: 'Martian Mono', monospace;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #4A3E28;
    margin-bottom: 0.5rem;
  }
  .readout-val {
    font-family: 'Martian Mono', monospace;
    font-size: 1.1rem;
    color: #F0A32C;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  /* Chart sections */
  .chart-section {
    margin-bottom: 2.5rem;
    animation: fade-up 0.35s ease both;
    animation-delay: 0.1s;
  }
  .section-rule {
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #4A3E28;
    border-bottom: 1px solid #2A2418;
    padding-bottom: 0.4rem;
    margin-bottom: 0.75rem;
  }
  .chart-frame {
    background: #0D0B07;
    border: 1px solid #2A2418;
    padding: 1rem;
    height: 240px;
    position: relative;
  }
  .chart-frame canvas {
    width: 100% !important;
    height: 100% !important;
  }
  .chart-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    color: #3E3420;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    pointer-events: none;
  }
  .chart-error {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Martian Mono', monospace;
    font-size: 0.65rem;
    color: #4A3E28;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* Tool table */
  .tool-table-wrap { overflow-x: auto; }
  .tool-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
  }
  .th {
    text-align: left;
    padding: 0 0 0.4rem;
    color: #4A3E28;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 1px solid #2A2418;
  }
  .th-right { text-align: right; }
  .tr { border-bottom: 1px solid #1C1408; }
  .tr:hover { background: #100E06; }
  .td { padding: 0.35rem 0; color: #7A6A42; vertical-align: middle; }
  .td-rank { color: #3E3420; width: 2.5rem; }
  .td-right { text-align: right; }
  .td-val { color: #F0A32C; }
  .td-dim { color: #4A3E28; }

  .tool-bar-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .tool-name {
    min-width: 180px;
    color: #C8B888;
  }
  .tool-bar {
    display: inline-block;
    height: 4px;
    background: #2A2418;
    flex-shrink: 0;
    position: relative;
  }
  .tool-bar::after {
    content: '';
    position: absolute;
    inset: 0;
    background: #F0A32C;
    opacity: 0.4;
  }

  @media (max-width: 900px) {
    .readout-strip { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .readout-strip { grid-template-columns: repeat(2, 1fr); }
  }
</style>
