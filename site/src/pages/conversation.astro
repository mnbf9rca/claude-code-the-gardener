---
import Layout from '../layouts/Layout.astro';
import { marked } from 'marked';
import conversationRaw from '../data/state/conversation.json';

type Message = {
  message_id?: string;
  timestamp: string;
  direction: 'to_human' | 'from_human';
  content: string;
  in_reply_to?: string | null;
};

const messages = (conversationRaw as Message[]).sort(
  (a, b) => a.timestamp.localeCompare(b.timestamp)
);

function fmtDate(ts: string) {
  return new Date(ts).toLocaleDateString('en-GB', {
    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC'
  });
}
function fmtTime(ts: string) {
  return new Date(ts).toLocaleTimeString('en-GB', {
    hour: '2-digit', minute: '2-digit', second: '2-digit', timeZone: 'UTC'
  });
}

// Group by date
const byDate: Array<{ date: string; msgs: (Message & { seq: number })[] }> = [];
let seq = 1;
for (const msg of messages) {
  const dateKey = msg.timestamp.slice(0, 10);
  const dateLabel = fmtDate(msg.timestamp);
  let group = byDate.find(g => g.date === dateKey);
  if (!group) {
    group = { date: dateKey, msgs: [] };
    byDate.push(group);
  }
  group.msgs.push({ ...msg, seq: seq++ });
}
---

<Layout title="Conversation">

  <div class="page-header">
    <div class="header-meta">TRANSMISSION LOG</div>
    <h1 class="page-title">Conversation</h1>
    <div class="header-count">{messages.length} messages</div>
  </div>

  {messages.length === 0 && (
    <div class="empty-log">
      <div class="empty-label">NO TRANSMISSIONS</div>
      <div class="empty-sub">No messages on record</div>
    </div>
  )}

  <div class="log">
    {byDate.map(group => (
      <div class="date-group">

        <!-- Date separator -->
        <div class="date-sep">
          <div class="date-sep-line"></div>
          <span class="date-sep-label">{fmtDate(group.msgs[0].timestamp)}</span>
          <div class="date-sep-line"></div>
        </div>

        <!-- Messages -->
        {group.msgs.map(msg => (
          msg.direction === 'to_human' ? (
            /* Agent transmission */
            <div class="msg-agent">
              <div class="msg-header">
                <span class="msg-seq">[{String(msg.seq).padStart(3, '0')}]</span>
                <span class="msg-from-agent">AGENT &rarr; HUMAN</span>
                <span class="msg-time">{fmtTime(msg.timestamp)} UTC</span>
              </div>
              <div class="msg-body-agent" set:html={marked.parse(msg.content)} />
            </div>
          ) : (
            /* Human annotation */
            <div class="msg-human">
              <div class="msg-header msg-header-human">
                <span class="msg-seq msg-seq-human">[{String(msg.seq).padStart(3, '0')}]</span>
                <span class="msg-from-human">HUMAN &rarr; AGENT</span>
                <span class="msg-time">{fmtTime(msg.timestamp)} UTC</span>
              </div>
              <div class="msg-body-human" set:html={marked.parse(msg.content)} />
            </div>
          )
        ))}
      </div>
    ))}
  </div>

</Layout>

<style>
  .page-header {
    border-bottom: 1px solid #2A2418;
    padding-bottom: 1.25rem;
    margin-bottom: 2.5rem;
    animation: fade-up 0.35s ease both;
  }
  .header-meta {
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #4A3E28;
    margin-bottom: 0.4rem;
  }
  .page-title {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 2rem;
    color: #E8D4A0;
    margin: 0 0 0.4rem;
    line-height: 1;
  }
  .header-count {
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    color: #6A5A3A;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .empty-log {
    text-align: center;
    padding: 4rem 2rem;
    border: 1px solid #1C1408;
  }
  .empty-label {
    font-family: 'Martian Mono', monospace;
    font-size: 0.7rem;
    color: #3E3420;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .empty-sub {
    font-family: 'Martian Mono', monospace;
    font-size: 0.55rem;
    color: #2A2018;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 0.4rem;
  }

  .log {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 780px;
    animation: fade-up 0.35s ease both;
    animation-delay: 0.08s;
  }

  .date-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Date separator */
  .date-sep {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 0.5rem 0;
  }
  .date-sep-line {
    flex: 1;
    height: 1px;
    background: #1C1408;
  }
  .date-sep-label {
    font-family: 'Martian Mono', monospace;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #3E3420;
    white-space: nowrap;
  }

  /* Shared message header */
  .msg-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.35rem 0.75rem;
    background: #0C0A06;
    border-bottom: 1px solid #2A2418;
  }
  .msg-seq {
    font-family: 'Martian Mono', monospace;
    font-size: 0.55rem;
    color: #3E3420;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .msg-time {
    font-family: 'Martian Mono', monospace;
    font-size: 0.55rem;
    color: #4A3E28;
    margin-left: auto;
    flex-shrink: 0;
  }

  /* Agent message */
  .msg-agent {
    border: 1px solid #2A2418;
    border-left: 2px solid #F0A32C;
    background: #100E06;
  }
  .msg-from-agent {
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #F0A32C;
  }
  .msg-body-agent {
    padding: 0.75rem;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 0.9rem;
    color: #C8B888;
    line-height: 1.7;
  }
  .msg-body-agent :global(p) { margin: 0 0 0.5rem; }
  .msg-body-agent :global(h1),
  .msg-body-agent :global(h2),
  .msg-body-agent :global(h3) {
    font-family: 'Martian Mono', monospace;
    font-style: normal;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #F0A32C;
    margin: 0.75rem 0 0.4rem;
  }
  .msg-body-agent :global(strong) { font-style: normal; color: #E8D4A0; font-weight: 600; }
  .msg-body-agent :global(ul),
  .msg-body-agent :global(ol) { margin: 0.25rem 0 0.5rem 1rem; padding: 0; }
  .msg-body-agent :global(li) { margin-bottom: 0.2rem; }

  /* Human message — inset, annotative style */
  .msg-human {
    margin-left: 3rem;
    border: 1px solid #1C2A1C;
    border-left: 2px solid #3A6A3A;
    background: #0A0F0A;
  }
  .msg-header-human {
    background: #080D08;
    border-bottom-color: #1C2A1C;
  }
  .msg-seq-human { color: #2A3E2A; }
  .msg-from-human {
    font-family: 'Martian Mono', monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6BAA5E;
  }
  .msg-body-human {
    padding: 0.75rem;
    font-family: 'Martian Mono', monospace;
    font-size: 0.7rem;
    color: #5A8A52;
    line-height: 1.7;
  }
  .msg-body-human :global(p) { margin: 0 0 0.4rem; }
  .msg-body-human :global(strong) { color: #8AC882; font-weight: 500; }
  .msg-body-human :global(ul),
  .msg-body-human :global(ol) { margin: 0.2rem 0 0.4rem 1rem; padding: 0; }
  .msg-body-human :global(li) { margin-bottom: 0.15rem; }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 600px) {
    .msg-human { margin-left: 1rem; }
  }
</style>
